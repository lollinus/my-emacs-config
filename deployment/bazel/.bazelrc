# Bazel flags for the Emacs build
#
# The Emacs build wraps GNU autoconf/make and needs access to system apt
# packages (libgccjit, libtree-sitter, libgtk-3, etc.), so sandboxing is
# disabled for the genrule targets via local = True in BUILD.bazel.

# Use bzlmod (MODULE.bazel) as the dependency system — required for Bazel 7+.
common --enable_bzlmod

# Keep Bazel output readable during long builds.
common --show_progress_rate_limit=5

# Allow genrules that use local=True to write to the home directory.
build --sandbox_writable_path=/tmp

# Track EMACS_REF as part of the Bazel cache key for //:emacs_ref_package.
# Different EMACS_REF values (branches, tags, SHAs) produce separate cached artifacts.
# Note: mutable refs (e.g. master) won't auto-invalidate when upstream advances.
# Force a rebuild with: EMACS_REF=master EMACS_REF_FORCE=$(date +%s) bazel build //:emacs_ref_package
build --action_env=EMACS_REF
build --action_env=EMACS_REF_FORCE

# Print test output on failure.
test --test_output=errors
